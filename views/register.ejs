<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <main class="register-main">
        <h1 class="h1-register">Registreer</h1>
        <div class="form-rectangle">
            <h2 class="h2-welkom">Welkom !</h2>
            <form class="registreer-form">
                <label for="vnaam" class="vnaam">Voornaam:</label>
                <input type="text" id="vnaam" name="vnaam">
                <label for="anaam" class="anaam">Achternaam:</label>
                <input type="text" id="anaam" name="anaam">
                <label for="email" class="email">Email:</label>
                <input type="text" id="email" name="email">
                <label for="wwoord" class="wwoord">Wachtwoord:</label>
                <input type="password" id="wwoord" name="wwoord">
                <p class="alac">Heb je al een account? <a href="#">Login</a></p>
                <input type="submit" id="register" name="register" value="Registreer">
            </form>
        </div>
    </main>
</body>
</html>