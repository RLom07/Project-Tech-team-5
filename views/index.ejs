<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cinematch</title>
    <%- include('partials/head') %>
</head>


<body>
    <div class="hero">
        <video autoplay loop muted class="background-video">
            <source src="../videos/fightclub-loop.mp4">
        </video>

        <header>
        <%- include('partials/header') %>
        </header>

        <main>
            <h1>CINEMATCH</h1>
            <h2>
                Stop met scrollen,<br>
                Start met kijken!
            </h2>
            <a href="/vragenlijst" class="primary-button"> Vind je match!</a>
        </main>
    </div>

    <section class="info">
        <ul>
            <li>
                <img src="../images/stemming.svg" alt="icoon stemming" loading="lazy" height="100">
                <h3>
                    Kies je stemming
                </h3>
            </li>
            <li>
                <img src="../images/match.svg" alt="icoon matching" loading="lazy" height="100">
                <h3>
                    Ontvang je match
                </h3>
            </li>
             <li>
                <img src="../images/favoriet.svg" alt="icoon favoriet" loading="lazy" height="100">
                <h3>
                    Bewaar je favoriet
                </h3>
            </li>
        </ul>
        <img class=background-dots src="../images/info-background.webp" alt="info background" aria-hidden="true" loading="lazy">

    </section>

    <section id="populair-movies">

        <h2>Populair deze week</h2>

        <div class="movie-grid">

            <% movies.forEach((movie, index) => { %>

                <a href="/movie/<%= movie.id %>" class="movie-card <%= index < 2 ? 'large' : '' %>">

                    <img src="https://image.tmdb.org/t/p/w300<%= movie.backdrop_path || movie.poster_path %>" alt="<%= movie.title %>" loading="lazy">
                
                    <h3><%= movie.title %></h3>
                    
                </a>

            <% }) %>

        </div>
    </section>

    <section id="gebruikers">
        <h2>
            82% gebruikers hebben <br> hun match sneller <br> gevonden met Cinematch!
        </h2>
        <img src="../images/graphic-icon.svg" alt="graphic-icon" loading="lazy">
    </section>


    <section id="trustpilot">

         <div>
            <h1>Onze reviews</h1>
        </div>
        
        <section id="review-box">
            <% if (reviews.length > 0) { %>
            <% reviews.forEach(review => { %>
            <article>
                <h2>Geschreven door <strong><%= review.voornaam  %></strong></h2>
                <p><%= review.name %></p>
                <p><%= review.text %></p>
                <p>Rating: <%= review.rating %></p>
                <% if (currentUserId && review.userId === currentUserId) { %>
                    <form action="/reviews/<%= review._id %>/delete" method="POST">
                    <div>
                        <button type="submit" class="verwijder-button" aria-label="Verwijder review">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M9 3h6l1 2h4v2H4V5h4l1-2zm-1 6h2v8H8V9zm6 0h2v8h-2V9zM7 9h10l-1 11H8L7 9z"/>
                        </svg>
                        </button>
                    </div>
                </form>
               <% } %>
            </article>
            <% }) %>
            <% } else { %>
            <p>Er zijn nog geen reviews.</p>
            <% } %>
        </section>
        <a href="/review" class="primary-button">Schrijf zelf een review!</a>
    </section>
    <section id="call-to-action">
        <h2>
            Waar wacht je nog op, <br> start met matchen!
        </h2>
        <ul>
            <li>
                <a href="/vragenlijst" class="primary-button"> Vind je match!</a>
                <a href="/login" class="inloggen">Inloggen</a>
            </li>
        </ul>
    </section>
    
    <footer>
        <%- include('partials/footer') %>
    </footer>
</body>
</html>
