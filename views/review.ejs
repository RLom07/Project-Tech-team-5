<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="review">
    <form action="/reviews" method="POST" id="reviewForm">  
        <h1>schrijf een review</h1>
        <h2>titel van review</h2>
        <textarea name="name" id="name"></textarea>
        <h2>Deel je ervaring</h2>
        <textarea name="text" id="text"></textarea>
        <h2>rating</h2>
        <label for="rating">rating (1 t/m 5)</label>
        <input name="rating" type="number" id="rating" min="1" max="5">
        <div><button class="primary-button" type="submit">Schrijf review</button></div>
    </form>
</body>
</html>