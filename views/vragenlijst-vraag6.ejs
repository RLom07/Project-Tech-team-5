<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="vragenlijst" data-stap="6">
    <main>
        <section>
            <h1>Welke taal heeft je voorkeur?</h1>
            <ul class="checkboxbutton-list">
                <li><button class="checkbox-button" onclick="kiesTaal('Engels')">Engels</button></li>
                <li><button class="checkbox-button" onclick="kiesTaal('Nederlands')">Nederlands</button></li>
            </ul>
            <ul class="checkboxbutton-list">
                <li><button class="checkbox-button" onclick="kiesTaal('Japans')">Japans</button></li>
                <li><button class="checkbox-button" onclick="kiesTaal('Geen voorkeur')">Geen voorkeur</button></li>
            </ul>
            <div class="volgende-vorige">
                <button onclick="window.location.href='/vragenlijst-vraag5'" id="vorige" class="primary-button">vorige</button>    
                <button onclick="window.location.href='/matching'" id="volgende" class="primary-button">volgende</button>
            </div>  
                 
        </section>
        <div class="container">
            <div class="stappen">
                <span class="cirkel actief">1</span>
                <span class="cirkel actief">2</span>
                <span class="cirkel actief">3</span>
                <span class="cirkel actief">4</span>
                <span class="cirkel actief">5</span>
                <span class="cirkel actief">6</span>
                <div class="progressie-bar">
                    <span class="indicator"></span>
                </div>
            </div>
        </div>
    </main>
    <script src="/scripts/main.js"></script>
</body>
</html>
