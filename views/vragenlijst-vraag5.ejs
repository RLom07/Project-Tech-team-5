<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="vragenlijst" data-stap="5">
    <main>
        <section>
            <h1>Welke leeftijdscategorie?</h1>
            <ul class="checkboxbutton-list">
