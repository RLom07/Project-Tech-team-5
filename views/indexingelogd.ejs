<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Welkom bij Cinematch!</title>
    <%- include('partials/head') %>
</head>


<body>
    <div class="hero">
        <video autoplay loop muted class="background-video">
            <source src="../videos/fightclub-loop.mp4">
        </video>

        <header>
        <%- include('partials/profileheader') %>
        </header>

        <main>
            <h1>CINEMATCH</h1>
            <h2>
                Stop met scrollen,<br>
                Start met kijken!
            </h2>
            <a href="/vragenlijst" class="primary-button"> Vind je match!</a>
        </main>
    </div>

    <section class="info">
        <ul>
            <li>
                <h1>
                   Hallo <%= gebruiker.voornaam %>, welkom terug!
                </h1>
                <a href="/profile" class="primary-button">Mijn overzicht</a>
                
            </li>
        </ul>
        <img class=background-dots src="../images/info-background.png" alt="info background" aria-hidden="true">
        
    </section>

    <section id="populair-movies">

        <h2>Populair deze week</h2>

        <div class="movie-grid">

            <% movies.forEach((movie, index) => { %>

                <a href="/movie/<%= movie.id %>" class="movie-card <%= index < 2 ? 'large' : '' %>">

                    <img src="https://image.tmdb.org/t/p/w780<%= movie.backdrop_path || movie.poster_path %>" alt="<%= movie.title %>" loading="lazy">
                
                    <h3><%= movie.title %></h3>
                    
                </a>

            <% }) %>

        </div>
    </section>

    <section id="gebruikers">
        <h2>
            82% gebruikers hebben <br> hun match sneller <br> gevonden met Cinematch!
        </h2>
        <img src="../images/graphic-icon.svg" alt="graphic-icon" loading="lazy">
    </section>


    <section id="trustpilot">

        <div>
            <h1>Onze reviews</h1>
        </div>
        
        <section id="review-box">
            <% if (reviews.length > 0) { %>
            <% reviews.forEach(review => { %>
            <article>
                <h2>Geschreven door <strong><%= gebruiker.voornaam.charAt(0).toUpperCase() + gebruiker.voornaam.slice(1) %></strong></h2>
                <p><%= review.name %></p>
                <p><%= review.text %></p>
                <p>Rating: <%= review.rating %></p>
                <% if (review.userId === currentUserId) { %>
                    <form action="/reviews/<%= review._id %>/delete" method="POST">
                    <div>
                        <button type="submit" class="verwijder-button" aria-label="Verwijder review">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M9 3h6l1 2h4v2H4V5h4l1-2zm-1 6h2v8H8V9zm6 0h2v8h-2V9zM7 9h10l-1 11H8L7 9z"/>
                        </svg>
                        </button>
                    </div>
                </form>
               <% } %>
            </article>
            <% }) %>
            <% } else { %>
            <p>Er zijn nog geen reviews.</p>
            <% } %>
        </section>
        <a href="/review" class="primary-button">Schrijf zelf een review!</a>
    </section>
