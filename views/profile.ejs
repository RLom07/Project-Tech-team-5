<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My profile</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/list.js/2.3.1/list.min.js"></script>
    <%- include('partials/head') %>
</head>
<body>
    <div class="hero">
        <video autoplay loop muted plays-inline class="background-video" aria-hidden="true">
            <source src="../videos/matrix-loop.mp4">
        </video>
        <header>
        <%- include('partials/profileheader') %>
        </header>
        <main>
            <h1> CINEMATCH</h1>
            <h2>
                <%= greeting %> <%= gebruiker.voornaam %>, Tijd voor je volgende match?
            </h2>
            <a  href="/vragenlijst" class="primary-button"> Vind je match</a>
        </main>
    </div>
    <section class="moviesCarousel">
        <h2>Favorieten</h2>
        <% if (favorites && favorites.length > 0) { %>
        <ul>
            <% favorites.forEach((movie) => { %>
            <li>
                <div class="posterWrapper">
                    <a href="/movie/<%= movie.id %>">
                        <img class="recentlyWatchedPosters" src="https://image.tmdb.org/t/p/w500<%= movie.poster_path %>" alt="<%= movie.title %>" loading="lazy">
                    </a>
                    <!-- Remove button -->
                    <button id="removeFavorite" class="removeBtn" data-id="<%= movie.id %>" aria-label="Verwijder film">✕</button>
                </div>
                <h3><%= movie.title %></h3>
            </li>
            <% }) %>
        </ul>
        <% } else { %>
            <p>Je hebt nog geen films toegevoegd aan uw favorieten.</p>
        <% } %>
    </section>
    <section class="moviesCarousel">
        <h2>Recentelijk bekeken</h2>
        <% if (recentlyWatched && recentlyWatched.length > 0) { %>
        <ul>
            <% recentlyWatched.slice(-6).reverse().forEach((movie) => { %>
            <li>
                <a href="/movie/<%= movie.id %>">
                    <img class="recentlyWatchedPosters" src="https://image.tmdb.org/t/p/w500<%= movie.poster_path %>" alt="<%= movie.title %>" loading="lazy">
                </a>
                <h3><%= movie.title %></h3>
            </li>
            <% }) %>
        </ul>
        <% } else { %>
            <p>Je hebt nog geen films in je watchlist.</p>
        <% } %>
    </section>
    <section id="watchList">
        <div id="watchListNav">
            <h2>Watchlist</h2>
            <aside>
                <img src="../images/list.png" alt="list icon" class="viewIcons" id="view-list" style="cursor:pointer;" onclick="showInList()">
                <img src="../images/grid.png" alt="grid icon" class="viewIcons" id="view-grid" style="cursor:pointer;" onclick="showInGrid()">
                Sorteren op:
                <button class="sort" data-sort="watchListName" style="cursor:pointer;">Naam </button>
            </aside>
        </div>
        <!-- Search input -->
        <input type="search" class="search" placeholder="  Zoek op naam">
        <!-- List.js container -->
        <% if (watchlist && watchlist.length > 0) { %>
            <ul class="list">
            <% watchlist.forEach((movie) => { %>
                <li>
                    <div class="posterWrapper">
                        <a href="/movie/<%= movie.id %>">
                            <img class="watchlistPosters" src="https://image.tmdb.org/t/p/w500<%= movie.poster_path %>" alt="<%= movie.title %>" loading="lazy">
                        </a>
                        <button id="removeWatchlist" class="removeBtn" data-id="<%= movie.id %>" aria-label="Verwijder film">✕</button>
                    </div>
                <section class="descriptionCards">
                    <h3 class="watchListName"><%= movie.title %></h3>
                    <h4><%= movie.release_date.slice(0,4) %> • 
                        <%= movie.runtime %> min • 
                        <%= movie.genres.slice(0,2).map(g => g.name).join(' / ') %></h4>
                    <p class="watchListDescription"><%= movie.overview %></p>
                </section>    
                </li>
            <% }) %>
            </ul>
        <% } else { %>
            <p>Je hebt nog geen films in je watchlist.</p>
        <% } %>
    </section>
    <section id="populair-movies">
        <h2>Populair deze week</h2>
        <div class="movie-grid">
            <% movies.forEach((movie, index) => { %>
                <a href="/movie/<%= movie.id %>" class="movie-card <%= index < 2 ? 'large' : '' %>">

                    <img src="https://image.tmdb.org/t/p/w780<%= movie.backdrop_path || movie.poster_path %>" alt="<%= movie.title %>" loading="lazy">
                
                    <h3><%= movie.title %></h3>                  
                </a>
            <% }) %>
        </div>
    </section>       
    <!-- List.js Initialization -->
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const buttons = document.querySelectorAll("#removeFavorite");

            buttons.forEach(button => {
                button.addEventListener("click", async (e) => {
                    e.preventDefault();

                    const movieId = button.dataset.id;

                    // Confirmation popup
                    const confirmed = confirm("Weet je zeker dat je deze film wilt verwijderen?");
                    if (!confirmed) return;

                    try {
                        const response = await fetch(`/favorites/${movieId}`, {
                            method: "DELETE"
                        });

                        if (response.ok) {
                            // Smooth removal animation
                            const li = button.closest("li");
                            li.style.transition = "0.3s";
                            li.style.opacity = "0";

                            setTimeout(() => li.remove(), 300);
                        } else {
                            alert("Verwijderen mislukt");
                        }
                    } catch (err) {
                        console.error(err);
                        alert("Er ging iets mis");
                    }
                });
            });
        });

        document.addEventListener("DOMContentLoaded", () => {
            const buttons = document.querySelectorAll("#removeWatchlist");

            buttons.forEach(button => {
                button.addEventListener("click", async (e) => {
                    e.preventDefault();

                    const movieId = button.dataset.id;

                    // Confirmation popup
                    const confirmed = confirm("Weet je zeker dat je deze film wilt verwijderen?");
                    if (!confirmed) return;

                    try {
                        const response = await fetch(`/watchlist/${movieId}`, {
                            method: "DELETE"
                        });

                        if (response.ok) {
                            // Smooth removal animation
                            const li = button.closest("li");
                            li.style.transition = "0.3s";
                            li.style.opacity = "0";

                            setTimeout(() => li.remove(), 300);
                        } else {
                            alert("Verwijderen mislukt");
                        }
                    } catch (err) {
                        console.error(err);
                        alert("Er ging iets mis");
                    }
                });
            });
        });


        document.addEventListener('DOMContentLoaded', function() {
            const options = {
                valueNames: ['watchListName', 'watchListDescription']
            };
            const watchList = new List('watchList', options);

            watchList.sort('watchListName', { order: "asc" });
        });


        const optionList = document.getElementById("view-list");
        const optionGrid = document.getElementById("view-grid");

        optionList.addEventListener("click", showInList);
        optionGrid.addEventListener("click", showInGrid);

        function showInGrid(){
        let view = document.querySelector('.list')
        view.classList.remove("list")    
        view.classList.add("grid")
        }

        function showInList(){
        let view = document.querySelector('.grid')

        view.classList.remove("grid")
        view.classList.add("list")
        }
    </script>
    <footer>
        <%- include('partials/footer') %>
    </footer>
</body>
</html>
